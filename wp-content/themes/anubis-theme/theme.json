{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "layout": {
      "contentSize": "1000px",
      "wideSize": "1440px"
    },
    "background": {
      "backgroundImage": true
    },
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#188FD9",
          "name": "Primary",
          "slug": "primary"
        },
        {
          "color": "#D10D0D",
          "name": "Restricted",
          "slug": "restricted"
        },
        {
          "color": "#088104",
          "name": "Good",
          "slug": "Good"
        },
        {
          "color": "#D7BA00",
          "name": "Warning",
          "slug": "warning"
        },
        {
          "color": "#242424",
          "name": "Black",
          "slug": "black"
        },
        {
          "color": "#EBEBEB",
          "name": "White",
          "slug": "white"
        },
        {
          "color": "#DDDDDD",
          "name": "Grey Light",
          "slug": "grey-light"
        }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true,
      "units": ["px", "%", "em", "rem", "vw", "vh"],
      "spacingSizes": [
        {
          "name": "Très très Petit",
          "size": "5px",
          "slug": "xxs"
        },
        {
          "name": "Très Petit",
          "size": "10px",
          "slug": "xs"
        },
        {
          "name": "Petit",
          "size": "20px",
          "slug": "sm"
        },
        {
          "name": "Moyen",
          "size": "40px",
          "slug": "md"
        },
        {
          "name": "Large",
          "size": "60px",
          "slug": "lg"
        },
        {
          "name": "X Large",
          "size": "80px",
          "slug": "xl"
        },
        {
          "name": "XX Large",
          "size": "100px",
          "slug": "xxl"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "customFontSize": true,
      "fontFamilies": [
        {
          "name": "Primary",
          "slug": "primary",
          "fontFamily": "'Outfit', sans-serif",
          "fontFace": [
            {
              "fontFamily": "Outfit",
              "fontWeight": "200",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": ["file:./resources/fonts/outfit/outfit-extralight.ttf"]
            },
            {
              "fontFamily": "Outfit",
              "fontWeight": "400",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": ["file:./resources/fonts/outfit/outfit-regular.ttf"]
            }
          ]
        },
        {
          "name": "Console",
          "slug": "console",
          "fontFamily": "Aldrich, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "sm",
          "size": "12px",
          "name": "Petit"
        },
        {
          "slug": "base",
          "size": "16px",
          "name": "Base"
        },
        {
          "slug": "lg",
          "size": "24px",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "36px",
          "name": "Extra Large"
        }
      ]
    },
    "blocks": {
      "core/paragraph": {
        "typography": {
          "fontSize": true
        }
      },
      "core/heading": {
        "typography": {
          "fontSize": true
        }
      },
      "core/image": {
        "lightbox": {
          "enabled": false
        }
      }
    }
  },
  "styles": {
    "color": {
      "text": "var:preset|color|black"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|primary",
      "fontSize": "var:preset|font-size|base",
      "fontWeight": "200"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontSize": "var:preset|font-size|xl",
          "fontWeight": "200"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|xl"
        },
        "spacing": {
          "margin": {
            "bottom": "var:preset|spacing|md"
          }
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|lg"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|md",
            "bottom": "var:preset|spacing|sm"
          }
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|lg"
        },
        "spacing": {
          "margin": {
			      "top": "var:preset|spacing|md",
            "bottom": "var:preset|spacing|sm"
          }
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|primary"
        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "typography": {
            "textDecoration": "underline"
          }
        }
      }
    }
  }
}
